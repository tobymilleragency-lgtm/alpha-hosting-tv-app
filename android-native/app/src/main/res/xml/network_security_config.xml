<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      IPTV providers (Xtream Codes, Stalker portals, naked M3U hosts) commonly
      ship HTTP-only endpoints, so we keep cleartext allowed by default.

      The GitHub Releases auto-update flow and the Cloudflare Worker telemetry
      endpoints are pinned to TLS — any plain-HTTP attempt to those hosts
      fails, defeating a downgrade attack on the update channel.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">github.com</domain>
        <domain includeSubdomains="true">githubusercontent.com</domain>
        <domain includeSubdomains="true">api.github.com</domain>
    </domain-config>
</network-security-config>
