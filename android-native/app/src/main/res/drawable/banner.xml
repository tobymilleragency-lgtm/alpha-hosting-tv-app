<?xml version="1.0" encoding="utf-8"?>
<!--
  Android TV banner (320×180). Variant C: red gradient background, broadcast
  arcs emanating from a dot on the left, play triangle in the centre, "ULTRA TV"
  wordmark on the right.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Red gradient background -->
    <path android:pathData="M0,0h320v180h-320z">
        <aapt:attr name="android:fillColor" xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="320"
                android:endY="180">
                <item android:color="#FFFF3A2F" android:offset="0.0"/>
                <item android:color="#FF7A0E08" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Broadcast arcs (concentric, from the emitter dot at 50,130) -->
    <path
        android:pathData="M 26,160 A 50,50 0 0 1 76,110"
        android:strokeColor="#F2FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M 16,170 A 80,80 0 0 1 96,90"
        android:strokeColor="#99FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M 6,180 A 110,110 0 0 1 116,70"
        android:strokeColor="#52FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"/>

    <!-- Emitter dot -->
    <path
        android:pathData="M 50,130 m -5,0 a 5,5 0 1,0 10,0 a 5,5 0 1,0 -10,0"
        android:fillColor="#FFFFFFFF"/>

    <!-- Play triangle -->
    <path
        android:pathData="M 130,55 L 130,125 L 195,90 Z"
        android:fillColor="#FFFFFFFF"/>

    <!-- Wordmark — drawn as stroked paths via Text would not render in vector;
         we mimic the wordmark with two horizontal bars suggesting "ULTRA / TV". -->
    <path android:pathData="M 215,80 L 295,80" android:strokeColor="#FFFFFFFF" android:strokeWidth="3" android:strokeLineCap="round"/>
    <path android:pathData="M 215,100 L 270,100" android:strokeColor="#CCFFFFFF" android:strokeWidth="3" android:strokeLineCap="round"/>
</vector>
