# Dependencies
node_modules/
**/node_modules/

# Builds
dist/
build/
release/
*.local

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp

# Secrets — never commit
.env
.env.local
.env.*.local
*.token
*-secrets.*

# Vite
.vite/

# Cloudflare / Vercel / Deno deploy local state
.wrangler/
.vercel/

# Electron
electron/release/

# Android — generated / large / per-developer
android-app/android/.gradle/
android-app/android/local.properties
android-app/android/app/build/
android-app/android/build/
android-app/android/app/release/
android-app/android/captures/
android-app/android/app/.cxx/
android-app/android/.idea/
android-app/android/*.iml
android-app/android/app/*.iml

# Capacitor copied web assets (regenerated by `cap sync`)
android-app/android/app/src/main/assets/public/

# Compiled JS from TS (legacy artefacts)
web/src/**/*.js
web/src/**/*.js.map
web/src/**/*.d.ts

# Logs
*.log
npm-debug.log*

# APK signing keys
*.keystore
*.jks

# (No blanket excludes for top-level src folders — would shadow web/src/app, web/src/data, …)

web/tsconfig.tsbuildinfo
web/vite.config.js

# Android native build
android-native/.gradle/
android-native/local.properties
android-native/app/build/
android-native/.kotlin/
android-native/build/

# Cloudflare wrangler
.wrangler/
**/.wrangler/
.claude/
